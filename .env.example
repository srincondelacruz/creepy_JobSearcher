# Copy to .env and fill in your values
# Load with: set -a; source .env; set +a

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Optional separate cheaper deployment for light tasks:
# AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini

# ─── Joinrs ───────────────────────────────────────────────────────────────────
JOINRS_EMAIL=your@email.com
JOINRS_PASSWORD=yourpassword

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_CHAT_ID=123456789           # your personal chat ID
TELEGRAM_ALLOWED_USER_IDS=123456789  # comma-separated, leave empty to allow all
